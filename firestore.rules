rules_version = '2';

// ETECHS QA/QC - Firestore Security Rules
// Paste into: Firebase Console > Firestore Database > Rules > Publish
service cloud.firestore {
  match /databases/{database}/documents {

    // ===================== HELPERS =====================
    // All helpers are declared up-front so every match block can use them.

    function authed() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return authed() && request.auth.uid == uid;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return authed() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return userExists() && userDoc().role == 'admin';
    }

    // True when the signed-in user holds the 'reopen' permission.
    function hasReopenPerm() {
      return userExists() && userDoc().get('perms', {}).get('reopen', false) == true;
    }

    // Guards /pending against ever holding a plaintext password.
    function noPasswordField() {
      return !request.resource.data.keys().hasAny(['pass', 'password']);
    }

    // ===================== USERS =====================
    // A user can never grant themselves a role or extra permissions.
    match /users/{uid} {
      allow read: if isSelf(uid) || isAdmin();

      // Two legitimate ways to create your own user document:
      //  1. As a plain 'user' (the normal case, incl. admin-invited engineers).
      //  2. As 'admin', but ONLY if you are the uid recorded in meta/bootstrap.
      //     The app writes meta/bootstrap first for the very first account, and
      //     that document can never be created twice or modified afterwards.
      allow create: if isSelf(uid) && (
        request.resource.data.role == 'user' ||
        (
          exists(/databases/$(database)/documents/meta/bootstrap) &&
          get(/databases/$(database)/documents/meta/bootstrap).data.adminUid == request.auth.uid
        )
      );

      // Self-update is allowed only when role and perms are unchanged.
      allow update: if isAdmin() || (
        isSelf(uid) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.get('perms', {}) == resource.data.get('perms', {})
      );

      allow delete: if isAdmin();
    }

    // ===================== META =====================
    // bootstrap is written once, when the very first account is created.
    // It anchors the admin rule above, so it must never change afterwards.
    match /meta/bootstrap {
      allow read: if authed();
      allow create: if authed() && !exists(/databases/$(database)/documents/meta/bootstrap);
      allow update: if false;
      allow delete: if false;
    }

    match /meta/lock {
      allow read: if authed();
      allow write: if isAdmin();
    }

    match /meta/announce {
      allow read: if authed();
      allow write: if isAdmin();
    }

    // No catch-all for /meta: Firestore ORs every matching rule, so a broad
    // "match /meta/{docId}" would re-open meta/bootstrap to admins.

    // ===================== PENDING INVITES =====================
    // A pending doc holds only { name, email, role }. The invite password is
    // NEVER stored: the engineer types it at first login, where Firebase Auth
    // creates their account. The create/update rules enforce that at the
    // database level, so even a buggy or tampered client cannot write one here.
    // Note: create/update/delete are listed separately because on a delete
    // request.resource is null, and touching request.resource.data would fail.
    match /pending/{email} {
      allow read: if isAdmin() || (authed() && request.auth.token.email == email);
      allow create: if isAdmin() && noPasswordField();
      allow update: if isAdmin() && noPasswordField();
      allow delete: if isAdmin();
    }

    // ===================== APP CONFIG =====================
    match /config/{docId} {
      allow read: if authed();
      allow write: if isAdmin();
    }

    // ===================== REPORTS =====================
    // A submitted ('done') report is frozen. The only permitted change is
    // unlocking it back to 'draft', by an admin or a user with 'reopen'.
    match /reports/{rid} {
      allow read: if isAdmin() || (authed() && resource.data.owner == request.auth.uid);

      allow create: if authed() && request.resource.data.owner == request.auth.uid;

      allow update: if isAdmin() ||
        (
          authed() &&
          resource.data.owner == request.auth.uid &&
          resource.data.status != 'done'
        ) ||
        (
          authed() &&
          hasReopenPerm() &&
          resource.data.status == 'done' &&
          request.resource.data.status == 'draft'
        );

      allow delete: if isAdmin();
    }

    // ===================== NON-CONFORMITIES =====================
    // Auto-generated NCRs carry the REPORT OWNER as 'owner', not the person
    // clicking, so an admin running backfill writes docs owned by someone else.
    match /ncr/{nid} {
      allow read: if authed();

      allow create: if authed() && (
        request.resource.data.owner == request.auth.uid ||
        isAdmin()
      );

      // Admin, the owner, whoever raised it, or the person responsible for
      // closing it may update (set status, corrective action, etc).
      allow update: if isAdmin() ||
        (authed() && resource.data.get('owner', '') == request.auth.uid) ||
        (authed() && resource.data.get('raisedBy', '') == request.auth.uid) ||
        (
          userExists() &&
          resource.data.get('responsible', '') != '' &&
          resource.data.get('responsible', '') == userDoc().get('name', '')
        );

      allow delete: if isAdmin();
    }

    // ===================== INSPECTION SCHEDULE =====================
    match /schedule/{sid} {
      allow read: if authed();
      allow create: if authed() && request.resource.data.owner == request.auth.uid;
      allow update: if isAdmin() || (authed() && resource.data.owner == request.auth.uid);
      allow delete: if isAdmin() || (authed() && resource.data.owner == request.auth.uid);
    }

    // ===================== PROCEDURES =====================
    match /procs/{pid} {
      allow read: if authed();
      allow write: if isAdmin();
    }

    // ===================== RISK REGISTER =====================
    match /risks/{rid} {
      allow read: if authed();
      allow write: if isAdmin();
    }

    // ===================== ACTIVITY LOG (append-only) =====================
    match /activity/{aid} {
      allow read: if isAdmin();
      allow create: if authed() && request.resource.data.byUid == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ===================== DEFAULT DENY =====================
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
