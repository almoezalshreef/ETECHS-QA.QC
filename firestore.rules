rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function authed() { return request.auth != null; }
    function isAdmin() {
      return authed() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isSelf(uid) { return authed() && request.auth.uid == uid; }

    // ---------- users ----------
    // Prevent privilege escalation: users can never change their own role/perms.
    match /users/{uid} {
      allow read: if isSelf(uid) || isAdmin();

      // First-ever user becomes admin (bootstrap doc doesn't exist yet).
      // Everyone else can self-create ONLY with role 'user',
      // or with the exact role pre-assigned by admin in /pending/{email}.
      allow create: if isSelf(uid) && (
        !exists(/databases/$(database)/documents/meta/bootstrap)
        || request.resource.data.role == 'user'
        || (
          exists(/databases/$(database)/documents/pending/$(request.auth.token.email))
          && request.resource.data.role ==
             get(/databases/$(database)/documents/pending/$(request.auth.token.email)).data.role
        )
      );

      // Self-update allowed only if role & perms unchanged. Admin can update anyone.
      allow update: if isAdmin() || (
        isSelf(uid)
        && request.resource.data.role == resource.data.role
        && request.resource.data.perms == resource.data.perms
      );

      allow delete: if isAdmin();
    }

    // ---------- meta ----------
    // bootstrap: written exactly once when the very first account is created.
    // It is the anchor that stops anyone else from self-assigning the admin role,
    // so it must never be updatable or deletable.
    match /meta/bootstrap {
      allow read: if authed();
      allow create: if authed() && !exists(/databases/$(database)/documents/meta/bootstrap);
      allow update, delete: if false;
    }
    // lock (app kill-switch) and announce (banner) are admin-controlled.
    match /meta/lock {
      allow read: if authed();
      allow write: if isAdmin();
    }
    match /meta/announce {
      allow read: if authed();
      allow write: if isAdmin();
    }
    // NOTE: Firestore evaluates ALL matching rules and ORs the results.
    // A catch-all `match /meta/{docId}` with `allow write: if isAdmin()` would
    // therefore re-open meta/bootstrap to admins and defeat its create-once
    // protection. So meta docs are whitelisted explicitly, with no catch-all.

    // ---------- pending (admin pre-assigned accounts) ----------
    match /pending/{email} {
      // a user may read only their own pending doc; admin reads all
      allow read: if isAdmin() || (authed() && request.auth.token.email == email);
      allow write: if isAdmin();
    }

    // ---------- app config (projects, templates, rules, recipient) ----------
    match /config/{docId} {
      allow read: if authed();
      allow write: if isAdmin();
    }

    // ---------- reports ----------
    // Safe lookup: never fail the rule if the user doc is missing.
    function hasReopenPerm() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid))
             .data.get('perms', {}).get('reopen', false) == true;
    }
    match /reports/{rid} {
      // owner reads own reports; admin everything
      allow read: if isAdmin() || (authed() && resource.data.owner == request.auth.uid);
      allow create: if authed() && request.resource.data.owner == request.auth.uid;

      // LOCK RULE
      // - a draft may be edited freely by its owner
      // - a report with status 'done' is FROZEN: nobody may change its content.
      //   The only permitted change is unlocking it (status done -> draft),
      //   and only by an admin or a user holding the 'reopen' permission.
      allow update: if isAdmin()
        || (
          // owner editing their own report while it is still a draft
          authed()
          && resource.data.owner == request.auth.uid
          && resource.data.status != 'done'
        )
        || (
          // unlocking a closed report: status is the thing being changed
          authed()
          && hasReopenPerm()
          && resource.data.status == 'done'
          && request.resource.data.status == 'draft'
        );

      allow delete: if isAdmin();
    }

    // ---------- NCR (non-conformities, incl. auto-generated) ----------
    // Auto-NCRs are created by syncReportNCRs / backfillNCRs. Their `owner` is the
    // ENGINEER WHO WROTE THE REPORT, not necessarily the person clicking. That means
    // an admin running backfill creates docs owned by someone else — allowed below.
    function ncrIsMine() {
      return authed() && (
        resource.data.get('owner', '') == request.auth.uid
        || resource.data.get('raisedBy', '') == request.auth.uid
        || (resource.data.get('responsible', '') != ''
            && resource.data.get('responsible', '') == userName())
      );
    }
    // Safe: returns '' when the user doc is missing instead of failing the rule.
    function userName() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('name', '')
        : '';
    }
    // An auto-NCR must point at a report the caller may legitimately act on.
    function ncrFromOwnReport() {
      let rid = request.resource.data.get('reportId', '');
      return rid != ''
        && exists(/databases/$(database)/documents/reports/$(rid))
        && get(/databases/$(database)/documents/reports/$(rid)).data.owner == request.resource.data.get('owner', '');
    }
    match /ncr/{nid} {
      // everyone signed in can read the register (the dashboard aggregates it)
      allow read: if authed();

      // create: manual NCR owned by the caller, OR an auto-NCR generated from a
      // report (admin backfill, or the report owner submitting).
      allow create: if authed() && (
        request.resource.data.owner == request.auth.uid
        || (isAdmin() && ncrFromOwnReport())
        || (request.resource.data.get('source','') == 'report' && ncrFromOwnReport())
      );

      // update: admin, the owner, whoever raised it, or the person accountable
      // for closing it (so they can set status / corrective action).
      allow update: if isAdmin() || ncrIsMine();

      allow delete: if isAdmin();
    }

    // ---------- inspection schedule ----------
    // Engineers manage their own planned inspections; admin sees/edits everything.
    // The app also auto-marks a slot 'done' when a matching report is submitted.
    match /schedule/{sid} {
      allow read: if authed();
      allow create: if authed() && request.resource.data.owner == request.auth.uid;
      allow update: if isAdmin() || (authed() && resource.data.owner == request.auth.uid);
      allow delete: if isAdmin() || (authed() && resource.data.owner == request.auth.uid);
    }

    // ---------- procedures & work instructions ----------
    match /procs/{pid} {
      allow read: if authed();
      allow write: if isAdmin();
    }

    // ---------- risk register ----------
    match /risks/{rid} {
      allow read: if authed();
      allow write: if isAdmin();
    }

    // ---------- activity log (append-only) ----------
    match /activity/{aid} {
      allow read: if isAdmin();
      allow create: if authed() && request.resource.data.byUid == request.auth.uid;
      allow update, delete: if false;
    }

    // ---------- default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
